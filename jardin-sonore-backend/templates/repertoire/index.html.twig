{% extends 'internal/base.html.twig' %}

{% set title = 'sessions.repertoire.index.title'|trans({}, 'sessions') %}

{% block internal_body %}
    <section class="internal-page-heading">
        <div>
            <p class="internal-eyebrow">{{ 'sessions.repertoire.index.eyebrow'|trans({}, 'sessions') }}</p>
            <h1>{{ 'sessions.repertoire.index.heading'|trans({}, 'sessions') }}</h1>
            <p>{{ 'sessions.repertoire.index.description'|trans({}, 'sessions') }}</p>
        </div>
        <a class="internal-button" href="{{ path('repertoire_new') }}">{{ 'sessions.repertoire.index.create'|trans({}, 'sessions') }}</a>
    </section>
    <section class="internal-card">
        <form class="internal-search" method="get">
            {% if sessionQuery %}<input type="hidden" name="session" value="{{ sessionQuery }}">{% endif %}
            <div>
                <div class="internal-search__field">
                    <label for="repertoire-query">{{ 'sessions.repertoire.index.search'|trans({}, 'sessions') }}</label>
                    <input id="repertoire-query" name="query" value="{{ query }}">
                </div>
                <div class="internal-search__field internal-search__field--compact">
                    <label for="repertoire-type">{{ 'sessions.repertoire.index.type'|trans({}, 'sessions') }}</label>
                    <select id="repertoire-type" name="type">
                        <option value="">{{ 'sessions.repertoire.index.all_types'|trans({}, 'sessions') }}</option>
                        {% for repertoireType in repertoireTypes %}
                            <option value="{{ repertoireType.value }}" {% if selectedType == repertoireType %}selected{% endif %}>{{ repertoireType.translationKey()|trans({}, 'sessions') }}</option>
                        {% endfor %}
                    </select>
                </div>
                <button class="internal-button internal-button--secondary" type="submit">{{ 'sessions.repertoire.index.search_submit'|trans({}, 'sessions') }}</button>
            </div>
        </form>
        {% if items is empty %}
            <p class="internal-empty-state">{{ 'sessions.repertoire.index.empty'|trans({}, 'sessions') }}</p>
        {% else %}
            <div class="internal-table-wrapper">
                <table class="internal-table internal-table--responsive">
                    <thead><tr><th>{{ 'sessions.repertoire.table.type'|trans({}, 'sessions') }}</th><th>{{ 'sessions.repertoire.table.title'|trans({}, 'sessions') }}</th><th>{{ 'sessions.repertoire.table.actions'|trans({}, 'sessions') }}</th></tr></thead>
                    <tbody>
                    {% for item in items %}
                        <tr>
                            <td data-label="{{ 'sessions.repertoire.table.type'|trans({}, 'sessions') }}">
                                <span class="internal-badge internal-badge--primary">{{ item.type.translationKey()|trans({}, 'sessions') }}</span>
                            </td>
                            <td data-label="{{ 'sessions.repertoire.table.title'|trans({}, 'sessions') }}"><strong>{{ item.title }}</strong></td>
                            <td data-label="{{ 'sessions.repertoire.table.actions'|trans({}, 'sessions') }}">
                                <div class="instrument-catalog__actions">
                                    {% if sessionQuery %}
                                        <a class="internal-button internal-button--secondary internal-button--compact" href="{{ path('session_sequence_new', { uuid: sessionQuery, repertoire: item.uuid }) }}">{{ 'sessions.repertoire.table.insert'|trans({}, 'sessions') }}</a>
                                    {% endif %}
                                    <a class="internal-button internal-button--secondary internal-button--compact" href="{{ path('repertoire_edit', { uuid: item.uuid }) }}">{{ 'sessions.repertoire.table.edit'|trans({}, 'sessions') }}</a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </section>
{% endblock %}
