{% extends 'internal/base.html.twig' %}

{% set title = 'sessions.summary.edit.title'|trans({ title: session.title }, 'sessions') %}

{% block internal_body %}
    <section class="internal-page-heading">
        <div>
            <p class="internal-eyebrow">{{ 'sessions.summary.edit.eyebrow'|trans({}, 'sessions') }}</p>
            <h1>{{ session.title }}</h1>
            <p>{{ 'sessions.summary.edit.description'|trans({}, 'sessions') }}</p>
        </div>
        <div class="internal-heading-actions">
            <a class="internal-button internal-button--secondary" href="{{ path('session_show', { uuid: session.uuid }) }}">{{ 'sessions.summary.edit.preview'|trans({}, 'sessions') }}</a>
            <a class="internal-button internal-button--secondary" href="{{ path('session_index') }}">{{ 'sessions.summary.edit.back'|trans({}, 'sessions') }}</a>
        </div>
    </section>

    <section class="internal-card">
        {% if hasErrors %}
            <div class="internal-alert internal-alert--error">{{ 'sessions.summary.form.error_notice'|trans({}, 'sessions') }}</div>
        {% endif %}

        {% include 'session/_summary_form.html.twig' with {
            form: form,
            backPath: path('session_index'),
            backLabel: 'sessions.summary.edit.back'|trans({}, 'sessions'),
        } only %}
    </section>

    {% include 'session/_composer.html.twig' with { session: session } only %}
    <turbo-frame id="session-composer-overlay"></turbo-frame>
{% endblock %}
