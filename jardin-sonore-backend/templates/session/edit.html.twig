{% extends 'internal/base.html.twig' %}

{% set title = 'sessions.summary.edit.title'|trans({ title: session.title }, 'sessions') %}

{% block internal_body %}
    <section class="internal-page-heading">
        <div>
            <p class="internal-eyebrow">{{ 'sessions.summary.edit.eyebrow'|trans({}, 'sessions') }}</p>
            <h1>{{ session.title }}</h1>
            <p>{{ 'sessions.summary.edit.description'|trans({}, 'sessions') }}</p>
        </div>
        <div class="internal-heading-actions">
            <a class="internal-button internal-button--secondary" href="{{ path('session_show', { uuid: session.uuid }) }}">{{ 'sessions.summary.edit.preview'|trans({}, 'sessions') }}</a>
            <a class="internal-button internal-button--secondary" href="{{ path('session_index') }}">{{ 'sessions.summary.edit.back'|trans({}, 'sessions') }}</a>
        </div>
    </section>

    <section class="internal-card">
        {% if hasErrors %}
            <div class="internal-alert internal-alert--error">{{ 'sessions.summary.form.error_notice'|trans({}, 'sessions') }}</div>
        {% endif %}

        {% include 'session/_summary_form.html.twig' with {
            form: form,
            backPath: path('session_index'),
            backLabel: 'sessions.summary.edit.back'|trans({}, 'sessions'),
        } only %}
    </section>

    <section class="internal-card">
        <div class="internal-page-heading">
            <div>
                <p class="internal-eyebrow">{{ 'sessions.sequence.index.eyebrow'|trans({}, 'sessions') }}</p>
                <h2>{{ 'sessions.sequence.index.heading'|trans({}, 'sessions') }}</h2>
                <p>{{ 'sessions.sequence.index.description'|trans({}, 'sessions') }}</p>
            </div>
            <a class="internal-button" href="{{ path('session_sequence_new', { uuid: session.uuid }) }}">{{ 'sessions.sequence.index.add_free'|trans({}, 'sessions') }}</a>
        </div>

        <div class="instrument-catalog__actions" style="margin-bottom: 1rem;">
            <a class="internal-button internal-button--secondary internal-button--compact" href="{{ path('repertoire_index', { session: session.uuid }) }}">
                {{ 'sessions.sequence.index.import_repertoire'|trans({}, 'sessions') }}
            </a>
            <a class="internal-button internal-button--secondary internal-button--compact" href="{{ path('media_resource_index', { session: session.uuid }) }}">
                {{ 'sessions.sequence.index.import_media'|trans({}, 'sessions') }}
            </a>
            <a class="internal-button internal-button--secondary internal-button--compact" href="{{ path('session_recommendation_index', { session: session.uuid }) }}">
                {{ 'sessions.sequence.index.import_recommendation'|trans({}, 'sessions') }}
            </a>
        </div>

        {% if session.sequences is empty %}
            <div class="internal-empty-state">{{ 'sessions.sequence.index.empty'|trans({}, 'sessions') }}</div>
        {% else %}
            <div class="internal-table-wrapper">
                <table class="internal-table internal-table--responsive">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>{{ 'sessions.sequence.table.type'|trans({}, 'sessions') }}</th>
                            <th>{{ 'sessions.sequence.table.title'|trans({}, 'sessions') }}</th>
                            <th>{{ 'sessions.sequence.table.source'|trans({}, 'sessions') }}</th>
                            <th>{{ 'sessions.sequence.table.actions'|trans({}, 'sessions') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for sequence in session.sequences %}
                            <tr>
                                <td data-label="#">{{ loop.index }}</td>
                                <td data-label="{{ 'sessions.sequence.table.type'|trans({}, 'sessions') }}">
                                    <span class="internal-badge internal-badge--primary">{{ sequence.type.translationKey()|trans({}, 'sessions') }}</span>
                                </td>
                                <td data-label="{{ 'sessions.sequence.table.title'|trans({}, 'sessions') }}">
                                    <strong>{{ sequence.title }}</strong>
                                    {% if sequence.subtitle %}
                                        <span class="internal-table-note">{{ sequence.subtitle }}</span>
                                    {% endif %}
                                </td>
                                <td data-label="{{ 'sessions.sequence.table.source'|trans({}, 'sessions') }}">
                                    {{ sequence.sourceTitle ?? '—' }}
                                </td>
                                <td data-label="{{ 'sessions.sequence.table.actions'|trans({}, 'sessions') }}">
                                    <div class="instrument-catalog__actions">
                                        <form method="post" action="{{ path('session_sequence_move_up', { uuid: session.uuid, sequenceUuid: sequence.uuid }) }}">
                                            <button class="internal-button internal-button--secondary internal-button--compact" type="submit">↑</button>
                                        </form>
                                        <form method="post" action="{{ path('session_sequence_move_down', { uuid: session.uuid, sequenceUuid: sequence.uuid }) }}">
                                            <button class="internal-button internal-button--secondary internal-button--compact" type="submit">↓</button>
                                        </form>
                                        <a class="internal-button internal-button--secondary internal-button--compact" href="{{ path('session_sequence_edit', { uuid: session.uuid, sequenceUuid: sequence.uuid }) }}">{{ 'sessions.sequence.table.edit'|trans({}, 'sessions') }}</a>
                                        <form method="post" action="{{ path('session_sequence_remove', { uuid: session.uuid, sequenceUuid: sequence.uuid }) }}" onsubmit="return confirm('{{ 'sessions.sequence.table.remove_confirm'|trans({}, 'sessions') }}');">
                                            <button class="internal-button internal-button--secondary internal-button--compact" type="submit">{{ 'sessions.sequence.table.remove'|trans({}, 'sessions') }}</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </section>
{% endblock %}
