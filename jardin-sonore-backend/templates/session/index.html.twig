{% extends 'internal/base.html.twig' %}

{% set title = 'sessions.summary.index.title'|trans({}, 'sessions') %}

{% block internal_body %}
    <section class="internal-page-heading">
        <div>
            <p class="internal-eyebrow">{{ 'sessions.summary.index.eyebrow'|trans({}, 'sessions') }}</p>
            <h1>{{ 'sessions.summary.index.heading'|trans({}, 'sessions') }}</h1>
            <p>{{ 'sessions.summary.index.description'|trans({}, 'sessions') }}</p>
        </div>
        <a class="internal-button" href="{{ path('session_new') }}">{{ 'sessions.summary.index.create'|trans({}, 'sessions') }}</a>
    </section>

    <section class="internal-card">
        <form class="internal-search" method="get">
            <label for="session-query">{{ 'sessions.summary.index.search'|trans({}, 'sessions') }}</label>
            <div>
                <input id="session-query" name="query" value="{{ query }}">
                <button class="internal-button internal-button--secondary" type="submit">{{ 'sessions.summary.index.search_submit'|trans({}, 'sessions') }}</button>
            </div>
        </form>

        {% if sessions is empty %}
            <p class="internal-empty-state">{{ 'sessions.summary.index.empty'|trans({}, 'sessions') }}</p>
        {% else %}
            <div class="internal-table-wrapper">
                <table class="internal-table internal-table--responsive">
                    <thead>
                        <tr>
                            <th>{{ 'sessions.summary.table.title'|trans({}, 'sessions') }}</th>
                            <th>{{ 'sessions.summary.table.organization'|trans({}, 'sessions') }}</th>
                            <th>{{ 'sessions.summary.table.date'|trans({}, 'sessions') }}</th>
                            <th>{{ 'sessions.summary.table.sequence_count'|trans({}, 'sessions') }}</th>
                            <th>{{ 'sessions.summary.table.actions'|trans({}, 'sessions') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for session in sessions %}
                            <tr>
                                <td data-label="{{ 'sessions.summary.table.title'|trans({}, 'sessions') }}">
                                    <strong>{{ session.title }}</strong>
                                    {% if session.theme %}
                                        <span class="internal-table-note">{{ session.theme }}</span>
                                    {% endif %}
                                </td>
                                <td data-label="{{ 'sessions.summary.table.organization'|trans({}, 'sessions') }}">{{ session.organizationName }}</td>
                                <td data-label="{{ 'sessions.summary.table.date'|trans({}, 'sessions') }}">{{ session.sessionDate|date('d/m/Y') }}</td>
                                <td data-label="{{ 'sessions.summary.table.sequence_count'|trans({}, 'sessions') }}">{{ session.sequences|length }}</td>
                                <td data-label="{{ 'sessions.summary.table.actions'|trans({}, 'sessions') }}">
                                    <div class="instrument-catalog__actions">
                                        <a class="internal-button internal-button--secondary internal-button--compact" href="{{ path('session_show', { uuid: session.uuid }) }}">{{ 'sessions.summary.table.preview'|trans({}, 'sessions') }}</a>
                                        <a class="internal-button internal-button--secondary internal-button--compact" href="{{ path('session_edit', { uuid: session.uuid }) }}">{{ 'sessions.summary.table.edit'|trans({}, 'sessions') }}</a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </section>
{% endblock %}
