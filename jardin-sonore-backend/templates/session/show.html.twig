{% extends 'internal/base.html.twig' %}

{% set title = session.title %}

{% block internal_body %}
    <section class="internal-page-heading print:hidden">
        <div>
            <p class="internal-eyebrow">{{ 'sessions.preview.eyebrow'|trans({}, 'sessions') }}</p>
            <h1>{{ session.title }}</h1>
            <p>{{ 'sessions.preview.description'|trans({}, 'sessions') }}</p>
        </div>
        <div class="internal-heading-actions">
            <a class="internal-button internal-button--secondary" href="{{ path('session_edit', { uuid: session.uuid }) }}">{{ 'sessions.preview.edit'|trans({}, 'sessions') }}</a>
            <button class="internal-button" onclick="window.print()">{{ 'sessions.preview.print'|trans({}, 'sessions') }}</button>
        </div>
    </section>

    <article class="internal-card">
        <section class="internal-page-heading" style="margin-bottom: 2rem;">
            <div>
                <p class="internal-eyebrow">{{ session.sessionDate|date('d/m/Y') }}</p>
                <h1>{{ session.title }}</h1>
                {% if session.theme %}
                    <p>{{ session.theme }}</p>
                {% endif %}
            </div>
        </section>

        <section>
            {% for sequence in session.sequences %}
                <article class="internal-card" style="margin-bottom: 1rem;">
                    <p class="internal-eyebrow">{{ loop.index }} · {% if sequence.role %}{{ sequence.role }} · {% endif %}{{ sequence.type.translationKey()|trans({}, 'sessions') }}</p>
                    <h2>{{ sequence.title }}</h2>
                    {% if sequence.subtitle %}
                        <p>{{ sequence.subtitle }}</p>
                    {% endif %}

                    {% if sequence.body %}
                        <div style="margin-top: .75rem;">{{ sequence.body|nl2br }}</div>
                    {% endif %}

                    {% if sequence.gestures %}
                        <div style="margin-top: .75rem;">
                            <strong>{{ 'sessions.preview.gestures'|trans({}, 'sessions') }}</strong>
                            <p>{{ sequence.gestures|nl2br }}</p>
                        </div>
                    {% endif %}

                    {% if sequence.lyrics %}
                        <details style="margin-top: .75rem;" {% if sequence.showLyricsByDefault %}open{% endif %}>
                            <summary>{{ 'sessions.preview.lyrics'|trans({}, 'sessions') }}</summary>
                            <div style="margin-top: .5rem;">{{ sequence.lyrics|nl2br }}</div>
                        </details>
                    {% endif %}

                    {% if sequence.notes %}
                        <div style="margin-top: .75rem;">
                            <strong>{{ 'sessions.preview.notes'|trans({}, 'sessions') }}</strong>
                            <p>{{ sequence.notes|nl2br }}</p>
                        </div>
                    {% endif %}

                    {% if sequence.imageUrl %}
                        <div style="margin-top: .75rem;">
                            <img src="{{ sequence.imageUrl }}" alt="" style="max-width: 240px; border-radius: 1rem;">
                        </div>
                    {% endif %}

                    {% if sequence.primaryUrl or sequence.secondaryUrl %}
                        <ul style="margin-top: .75rem;">
                            {% if sequence.primaryUrl %}
                                <li><a href="{{ sequence.primaryUrl }}" target="_blank" rel="noopener noreferrer">{{ sequence.primaryUrl }}</a></li>
                            {% endif %}
                            {% if sequence.secondaryUrl %}
                                <li><a href="{{ sequence.secondaryUrl }}" target="_blank" rel="noopener noreferrer">{{ sequence.secondaryUrl }}</a></li>
                            {% endif %}
                        </ul>
                    {% endif %}
                </article>
            {% endfor %}
        </section>

    </article>
{% endblock %}
