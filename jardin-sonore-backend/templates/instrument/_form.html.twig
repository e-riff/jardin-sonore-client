{{ form_start(form, {
    attr: {
        class: 'internal-form'
    }
}) }}
    <div class="internal-form__grid">
        {{ form_row(form.name) }}
        {{ form_row(form.tuning) }}
    </div>

    <div class="internal-form__grid">
        {{ form_row(form.quantity) }}
        {{ form_row(form.active) }}
    </div>

    <div class="instrument-form__tags">
        {{ form_label(form.tagUuids) }}
        {{ form_errors(form.tagUuids) }}
        <div class="instrument-form__tags-list">
            {% for tagField in form.tagUuids %}
                <div class="instrument-form__tag-option">
                    {{ form_widget(tagField) }}
                    {{ form_label(tagField) }}
                </div>
            {% endfor %}
        </div>
    </div>
    {{ form_row(form.notes) }}

    <div class="internal-form__actions">
        {{ form_widget(form.submit) }}
        <a class="internal-button internal-button--secondary" href="{{ path('instrument_index') }}">
            {{ 'catalog.instrument.form.back'|trans({}, 'catalog') }}
        </a>
        {% if instrument is defined %}
            <button type="button" class="internal-button internal-button--danger" {{ stimulus_action('confirmation-dialog', 'open') }} data-confirmation-dialog-action-value="{{ path('instrument_delete', { uuid: instrument.uuid.toRfc4122 }) }}" data-confirmation-dialog-item-value="{{ instrument.name }}" data-confirmation-dialog-token-value="{{ csrf_token('instrument_delete_' ~ instrument.uuid.toRfc4122) }}">{{ 'catalog.instrument.table.delete'|trans({}, 'catalog') }}</button>
        {% endif %}
    </div>
{{ form_end(form) }}
