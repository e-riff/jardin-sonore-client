{% extends 'internal/base.html.twig' %}

{% set title = 'internal.dashboard.title'|trans({}, 'internal') %}

{% block internal_body %}
    <section class="internal-hero">
        <p class="internal-eyebrow">{{ 'internal.dashboard.eyebrow'|trans({}, 'internal') }}</p>
        <h1>{{ 'internal.dashboard.heading'|trans({}, 'internal') }}</h1>
        <p>
            {{ 'internal.dashboard.description'|trans({}, 'internal') }}
        </p>
    </section>

    <section class="internal-grid" aria-label="{{ 'internal.dashboard.modules_aria'|trans({}, 'internal') }}">
        <article class="internal-card">
            <h2>{{ 'internal.dashboard.mailing.title'|trans({}, 'internal') }}</h2>
            <p>{{ 'internal.dashboard.mailing.description'|trans({}, 'internal') }}</p>
            <a class="internal-button" href="{{ path('mailing_index') }}">{{ 'internal.dashboard.mailing.action'|trans({}, 'internal') }}</a>
        </article>

        <article class="internal-card">
            <h2>{{ 'internal.dashboard.backoffice.title'|trans({}, 'internal') }}</h2>
            <p>{{ 'internal.dashboard.backoffice.description'|trans({}, 'internal') }}</p>
            <a class="internal-button internal-button--secondary" href="{{ path('admin') }}">{{ 'internal.dashboard.backoffice.action'|trans({}, 'internal') }}</a>
        </article>
    </section>
{% endblock %}
