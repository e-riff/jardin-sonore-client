{% extends 'base.html.twig' %}

{% block title %}{{ title|default('internal.base.title'|trans({}, 'internal')) }}{% endblock %}

{% block body %}
    <div class="internal-shell">
        <header class="internal-header">
            <a class="internal-brand" href="{{ path('internal_dashboard') }}" aria-label="{{ 'internal.base.brand_aria'|trans({}, 'internal') }}">
                <span class="internal-brand__mark">JS</span>
                <span>
                    <strong>{{ 'internal.base.brand'|trans({}, 'internal') }}</strong>
                    <small>{{ 'internal.base.subtitle'|trans({}, 'internal') }}</small>
                </span>
            </a>

            <nav class="internal-nav" aria-label="{{ 'internal.base.navigation_aria'|trans({}, 'internal') }}">
                <a href="{{ path('internal_dashboard') }}">{{ 'internal.base.nav.dashboard'|trans({}, 'internal') }}</a>
                <a href="{{ path('mailing_index') }}">{{ 'internal.base.nav.mailing'|trans({}, 'internal') }}</a>
                <a href="{{ path('mailing_recommendation_catalog_index') }}">{{ 'internal.base.nav.recommendations'|trans({}, 'internal') }}</a>
                <a href="{{ path('admin') }}">{{ 'internal.base.nav.backoffice'|trans({}, 'internal') }}</a>
            </nav>
        </header>

        <main class="internal-main">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="internal-alert internal-alert--{{ label }}">
                        {{ message|trans({}, 'mailing') }}
                    </div>
                {% endfor %}
            {% endfor %}

            {% block internal_body %}{% endblock %}
        </main>
    </div>
{% endblock %}
