{% extends 'internal/base.html.twig' %}

{% set title = 'sessions.media.index.title'|trans({}, 'sessions') %}

{% block internal_body %}
    <section class="internal-page-heading">
        <div>
            <p class="internal-eyebrow">{{ 'sessions.media.index.eyebrow'|trans({}, 'sessions') }}</p>
            <h1>{{ 'sessions.media.index.heading'|trans({}, 'sessions') }}</h1>
            <p>{{ 'sessions.media.index.description'|trans({}, 'sessions') }}</p>
        </div>
        <a class="internal-button" href="{{ path('media_resource_new') }}">{{ 'sessions.media.index.create'|trans({}, 'sessions') }}</a>
    </section>
    <section class="internal-card">
        <form class="internal-search" method="get">
            {% if sessionQuery %}<input type="hidden" name="session" value="{{ sessionQuery }}">{% endif %}
            <div>
                <div class="internal-search__field">
                    <label for="media-query">{{ 'sessions.media.index.search'|trans({}, 'sessions') }}</label>
                    <input id="media-query" name="query" value="{{ query }}">
                </div>
                <div class="internal-search__field internal-search__field--compact">
                    <label for="media-type">{{ 'sessions.media.index.type'|trans({}, 'sessions') }}</label>
                    <select id="media-type" name="type">
                        <option value="">{{ 'sessions.media.index.all_types'|trans({}, 'sessions') }}</option>
                        {% for typeOption in typeOptions %}
                            <option value="{{ typeOption.value }}" {% if selectedType and selectedType == typeOption %}selected{% endif %}>{{ typeOption.translationKey()|trans({}, 'sessions') }}</option>
                        {% endfor %}
                    </select>
                </div>
                <button class="internal-button internal-button--secondary" type="submit">{{ 'sessions.media.index.search_submit'|trans({}, 'sessions') }}</button>
            </div>
        </form>
        {% if items is empty %}
            <p class="internal-empty-state">{{ 'sessions.media.index.empty'|trans({}, 'sessions') }}</p>
        {% else %}
            <div class="internal-table-wrapper">
                <table class="internal-table internal-table--responsive">
                    <thead><tr><th>{{ 'sessions.media.table.title'|trans({}, 'sessions') }}</th><th>{{ 'sessions.media.table.type'|trans({}, 'sessions') }}</th><th>{{ 'sessions.media.table.link'|trans({}, 'sessions') }}</th><th>{{ 'sessions.media.table.source'|trans({}, 'sessions') }}</th><th>{{ 'sessions.media.table.actions'|trans({}, 'sessions') }}</th></tr></thead>
                    <tbody>
                    {% for item in items %}
                        <tr>
                            <td data-label="{{ 'sessions.media.table.title'|trans({}, 'sessions') }}"><strong>{{ item.title }}</strong>{% if item.description %}<span class="internal-table-note">{{ item.description|length > 120 ? item.description|slice(0, 120) ~ '…' : item.description }}</span>{% endif %}</td>
                            <td data-label="{{ 'sessions.media.table.type'|trans({}, 'sessions') }}">{{ item.type.translationKey()|trans({}, 'sessions') }}</td>
                            <td data-label="{{ 'sessions.media.table.link'|trans({}, 'sessions') }}"><a class="internal-link" href="{{ item.primaryUrl }}" target="_blank" rel="noopener noreferrer">{{ item.primaryUrl|length > 56 ? item.primaryUrl|slice(0, 56) ~ '…' : item.primaryUrl }}</a></td>
                            <td data-label="{{ 'sessions.media.table.source'|trans({}, 'sessions') }}">{{ item.source ?? '—' }}</td>
                            <td data-label="{{ 'sessions.media.table.actions'|trans({}, 'sessions') }}"><div class="instrument-catalog__actions">{% if sessionQuery %}<a class="internal-button internal-button--secondary internal-button--compact" href="{{ path('session_sequence_new', { uuid: sessionQuery, media: item.uuid }) }}">{{ 'sessions.media.table.insert'|trans({}, 'sessions') }}</a>{% endif %}<a class="internal-button internal-button--secondary internal-button--compact" href="{{ path('media_resource_edit', { uuid: item.uuid }) }}">{{ 'sessions.media.table.edit'|trans({}, 'sessions') }}</a></div></td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </section>
{% endblock %}
