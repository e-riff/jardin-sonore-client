<div {{ attributes }} class="instrument-catalog">
    {% set result = this.catalogResult %}

    <section class="internal-card">
        <div class="instrument-catalog__controls">
            <div class="internal-search">
                <label for="instrument-query">{{ 'catalog.instrument.filters.query'|trans({}, 'catalog') }}</label>
                <div>
                    <input
                        id="instrument-query"
                        type="search"
                        value="{{ query }}"
                        data-model="debounce(300)|query"
                        placeholder="{{ 'catalog.instrument.filters.query_placeholder'|trans({}, 'catalog') }}"
                    >
                </div>
            </div>

            <div class="instrument-catalog__filters instrument-catalog__filters--compact">
                <div>
                    <label for="instrument-tags">{{ 'catalog.instrument.filters.tags'|trans({}, 'catalog') }}</label>
                    <div id="instrument-tags" class="instrument-catalog__tags">
                        {% for tagOption in this.tagOptions %}
                            <button
                                type="button"
                                class="internal-badge internal-badge--color instrument-catalog__tag-filter {{ this.isTagSelected(tagOption.uuid) ? 'is-selected' : '' }}"
                                style="--badge-color: {{ tagOption.color }}"
                                {{ live_action('toggleTag', { uuid: tagOption.uuid }) }}
                                aria-pressed="{{ this.isTagSelected(tagOption.uuid) ? 'true' : 'false' }}"
                            >
                                {{ tagOption.label }}
                            </button>
                        {% endfor %}
                    </div>
                </div>

                <div>
                    <label for="instrument-active">{{ 'catalog.instrument.filters.active'|trans({}, 'catalog') }}</label>
                    <select id="instrument-active" data-model="on(change)|activeFilter">
                        <option value="">{{ 'catalog.instrument.filters.all'|trans({}, 'catalog') }}</option>
                        <option value="active" {% if activeFilter == 'active' %}selected{% endif %}>{{ 'catalog.instrument.filters.active_only'|trans({}, 'catalog') }}</option>
                        <option value="inactive" {% if activeFilter == 'inactive' %}selected{% endif %}>{{ 'catalog.instrument.filters.inactive_only'|trans({}, 'catalog') }}</option>
                    </select>
                </div>

                <div>
                    <label for="instrument-quantity">{{ 'catalog.instrument.filters.quantity'|trans({}, 'catalog') }}</label>
                    <select id="instrument-quantity" data-model="on(change)|quantityFilter">
                        <option value="">{{ 'catalog.instrument.filters.all'|trans({}, 'catalog') }}</option>
                        <option value="with" {% if quantityFilter == 'with' %}selected{% endif %}>{{ 'catalog.instrument.filters.with_value'|trans({}, 'catalog') }}</option>
                        <option value="without" {% if quantityFilter == 'without' %}selected{% endif %}>{{ 'catalog.instrument.filters.without_value'|trans({}, 'catalog') }}</option>
                    </select>
                </div>

                <div>
                    <label for="instrument-tuning">{{ 'catalog.instrument.filters.tuning'|trans({}, 'catalog') }}</label>
                    <select id="instrument-tuning" data-model="on(change)|tuningFilter">
                        <option value="">{{ 'catalog.instrument.filters.all'|trans({}, 'catalog') }}</option>
                        <option value="with" {% if tuningFilter == 'with' %}selected{% endif %}>{{ 'catalog.instrument.filters.with_value'|trans({}, 'catalog') }}</option>
                        <option value="without" {% if tuningFilter == 'without' %}selected{% endif %}>{{ 'catalog.instrument.filters.without_value'|trans({}, 'catalog') }}</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="instrument-catalog__meta">
            <p>{{ 'catalog.instrument.index.total'|trans({ count: result.total }, 'catalog') }}</p>

            {% if this.hasActiveFilters %}
                <button
                    type="button"
                    class="internal-button internal-button--secondary internal-button--compact"
                    {{ live_action('resetFilters') }}
                >
                    {{ 'catalog.instrument.filters.reset'|trans({}, 'catalog') }}
                </button>
            {% endif %}
        </div>

        {% if result.items is empty %}
            <div class="internal-empty-state">
                {{ 'catalog.instrument.index.empty'|trans({}, 'catalog') }}
            </div>
        {% else %}
            <div class="internal-table-wrapper">
                <table class="internal-table">
                    <thead>
                        <tr>
                            {% for column, label in {
                                name: 'catalog.instrument.table.name',
                                tuning: 'catalog.instrument.table.tuning',
                                quantity: 'catalog.instrument.table.quantity'
                            } %}
                                <th>
                                    <button
                                        type="button"
                                        class="instrument-catalog__sort-button{% if this.isSortedBy(column) %} is-active{% endif %}"
                                        {{ live_action('sort', { column: column }) }}
                                    >
                                        <span>{{ label|trans({}, 'catalog') }}</span>
                                        <span aria-hidden="true">{{ this.sortIconFor(column) }}</span>
                                    </button>
                                </th>
                            {% endfor %}
                            <th>{{ 'catalog.instrument.table.tags'|trans({}, 'catalog') }}</th>
                            <th>{{ 'catalog.instrument.filters.active'|trans({}, 'catalog') }}</th>
                            <th>{{ 'catalog.instrument.table.actions'|trans({}, 'catalog') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for instrument in result.items %}
                            <tr class="internal-table__row--clickable" tabindex="0" data-controller="catalog-row" data-catalog-row-url-value="{{ path('instrument_edit', { uuid: instrument.uuid.toRfc4122 }) }}" data-action="click->catalog-row#navigate keydown->catalog-row#navigateFromKeyboard">
                                <td>
                                    <strong>{{ instrument.name }}</strong>
                                    {% if instrument.notes %}
                                        <span class="internal-table-note">
                                            {{ instrument.notes|length > 110 ? instrument.notes|slice(0, 110) ~ '…' : instrument.notes }}
                                        </span>
                                    {% endif %}
                                </td>
                                <td>{{ instrument.tuning ?? '—' }}</td>
                                <td>{{ instrument.quantity ?? '—' }}</td>
                                <td>
                                    {% if instrument.tags is empty %}
                                        <span class="internal-table-note">—</span>
                                    {% else %}
                                        <div class="instrument-catalog__tags">
                                            {% for tag in instrument.tags %}
                                                <span class="internal-badge internal-badge--color" style="--badge-color: {{ tag.color }}">{{ tag.label }}</span>
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </td>
                                <td><span class="internal-badge internal-badge--{{ instrument.active ? 'secondary' : 'primary' }}">{{ (instrument.active ? 'catalog.instrument.filters.active_only' : 'catalog.instrument.filters.inactive_only')|trans({}, 'catalog') }}</span></td>
                                <td data-catalog-row-ignore>
                                    {% include 'components/_catalog_actions.html.twig' with { editUrl: path('instrument_edit', { uuid: instrument.uuid.toRfc4122 }), deleteUrl: path('instrument_delete', { uuid: instrument.uuid.toRfc4122 }), itemLabel: instrument.name, token: csrf_token('instrument_delete_' ~ instrument.uuid.toRfc4122), editLabel: 'catalog.instrument.table.edit'|trans({}, 'catalog'), deleteLabel: 'catalog.instrument.table.delete'|trans({}, 'catalog') } only %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {% if this.pageCount > 1 %}
                <div class="instrument-catalog__pagination">
                    <button
                        type="button"
                        class="internal-button internal-button--secondary internal-button--compact"
                        {{ live_action('previousPage') }}
                        {% if page <= 1 %}disabled{% endif %}
                    >
                        {{ 'catalog.instrument.pagination.previous'|trans({}, 'catalog') }}
                    </button>

                    <span>{{ 'catalog.instrument.pagination.page'|trans({ current: page, total: this.pageCount }, 'catalog') }}</span>

                    <button
                        type="button"
                        class="internal-button internal-button--secondary internal-button--compact"
                        {{ live_action('nextPage') }}
                        {% if page >= this.pageCount %}disabled{% endif %}
                    >
                        {{ 'catalog.instrument.pagination.next'|trans({}, 'catalog') }}
                    </button>
                </div>
            {% endif %}
        {% endif %}
    </section>
</div>
