<div {{ attributes }} class="instrument-catalog">
    {% set items = this.items %}

    <section class="internal-card">
        <div class="instrument-catalog__controls instrument-catalog__controls--inline">
            <div class="internal-search">
                <div class="internal-search__row">
                    <div class="internal-search__field">
                        <label for="repertoire-query">{{ 'sessions.repertoire.index.search'|trans({}, 'sessions') }}</label>
                        <input
                            id="repertoire-query"
                            type="search"
                            value="{{ query }}"
                            data-model="debounce(300)|query"
                            placeholder="{{ 'sessions.repertoire.index.search_placeholder'|trans({}, 'sessions') }}"
                        >
                    </div>

                    <div class="internal-search__field internal-search__field--compact">
                        <label for="repertoire-type">{{ 'sessions.repertoire.index.type'|trans({}, 'sessions') }}</label>
                        <select id="repertoire-type" data-model="on(change)|type">
                            <option value="">{{ 'sessions.repertoire.index.all_types'|trans({}, 'sessions') }}</option>
                            {% for typeOption in this.typeOptions %}
                                <option value="{{ typeOption.value }}" {% if type == typeOption.value %}selected{% endif %}>{{ typeOption.translationKey()|trans({}, 'sessions') }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="internal-search__field internal-search__field--compact">
                        <label for="repertoire-active">{{ 'sessions.catalog.active'|trans({}, 'sessions') }}</label>
                        <select id="repertoire-active" data-model="on(change)|activeFilter">
                            <option value="active">{{ 'sessions.catalog.active_only'|trans({}, 'sessions') }}</option>
                            <option value="inactive">{{ 'sessions.catalog.inactive_only'|trans({}, 'sessions') }}</option>
                            <option value="all">{{ 'sessions.catalog.all'|trans({}, 'sessions') }}</option>
                        </select>
                    </div>
                    <div class="internal-search__field internal-search__field--themes"><span>{{ 'sessions.repertoire.form.themes'|trans({}, 'sessions') }}</span><div class="instrument-catalog__tags">{% for themeOption in this.themeOptions %}<button type="button" class="internal-badge internal-badge--color instrument-catalog__tag-filter {{ themeOption.uuid in themeUuids ? 'is-selected' : '' }}" style="--badge-color: {{ themeOption.color }}" {{ live_action('toggleTheme', { uuid: themeOption.uuid }) }} aria-pressed="{{ themeOption.uuid in themeUuids ? 'true' : 'false' }}">{{ themeOption.label }}</button>{% endfor %}</div></div>
                </div>
            </div>
        </div>

        <div class="instrument-catalog__meta">
            <p>{{ 'sessions.repertoire.index.total'|trans({ count: items|length }, 'sessions') }}</p>

            {% if this.hasActiveFilters %}
                <button
                    type="button"
                    class="internal-button internal-button--secondary internal-button--compact"
                    {{ live_action('resetFilters') }}
                >
                    {{ 'sessions.repertoire.index.reset'|trans({}, 'sessions') }}
                </button>
            {% endif %}
        </div>

        {% if items is empty %}
            <p class="internal-empty-state">{{ 'sessions.repertoire.index.empty'|trans({}, 'sessions') }}</p>
        {% else %}
            <div class="internal-table-wrapper">
                <table class="internal-table internal-table--responsive">
                    <thead>
                        <tr>
                            {% for column, label in {
                                type: 'sessions.repertoire.table.type',
                                title: 'sessions.repertoire.table.title', theme: 'sessions.repertoire.table.themes'
                            } %}
                                <th>
                                    <button
                                        type="button"
                                        class="instrument-catalog__sort-button{% if this.isSortedBy(column) %} is-active{% endif %}"
                                        {{ live_action('sort', { column: column }) }}
                                    >
                                        <span>{{ label|trans({}, 'sessions') }}</span>
                                        <span aria-hidden="true">{{ this.sortIconFor(column) }}</span>
                                    </button>
                                </th>
                            {% endfor %}
                            <th>{{ 'sessions.repertoire.table.actions'|trans({}, 'sessions') }}</th>
                            <th>{{ 'sessions.catalog.active'|trans({}, 'sessions') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in items %}
                            <tr class="internal-table__row--clickable" tabindex="0" data-controller="catalog-row" data-catalog-row-url-value="{{ path('repertoire_edit', { uuid: item.uuid.toRfc4122 }) }}" data-action="click->catalog-row#navigate keydown->catalog-row#navigateFromKeyboard">
                                <td data-label="{{ 'sessions.repertoire.table.type'|trans({}, 'sessions') }}">
                                    <span class="internal-badge {{ item.type.value == 'fingerplay' ? 'internal-badge--secondary' : 'internal-badge--primary' }}">{{ item.type.translationKey()|trans({}, 'sessions') }}</span>
                                </td>
                                <td data-label="{{ 'sessions.repertoire.table.title'|trans({}, 'sessions') }}">
                                    <strong>{{ item.title }}</strong>
                                    {% if item.source %}
                                        <span class="internal-table-note">{{ item.source }}</span>
                                    {% endif %}
                                </td>
                                <td data-label="{{ 'sessions.repertoire.table.themes'|trans({}, 'sessions') }}"><div class="instrument-catalog__tags">{% for theme in item.themes %}<span class="internal-badge internal-badge--color" style="--badge-color: {{ theme.color }}">{{ theme.label }}</span>{% endfor %}</div></td>
                                <td data-catalog-row-ignore data-label="{{ 'sessions.repertoire.table.actions'|trans({}, 'sessions') }}">
                                    <div class="instrument-catalog__actions">
                                        {% if sessionQuery %}
                                            <a class="internal-button internal-button--secondary internal-button--compact" href="{{ path('session_sequence_new', { uuid: sessionQuery, repertoire: item.uuid.toRfc4122 }) }}">
                                                {{ 'sessions.repertoire.table.insert'|trans({}, 'sessions') }}
                                            </a>
                                        {% endif %}
                                        {% include 'components/_catalog_actions.html.twig' with { editUrl: path('repertoire_edit', { uuid: item.uuid.toRfc4122 }), deleteUrl: path('repertoire_delete', { uuid: item.uuid.toRfc4122 }), itemLabel: item.title, token: csrf_token('repertoire_delete_' ~ item.uuid.toRfc4122), editLabel: 'sessions.repertoire.table.edit'|trans({}, 'sessions'), deleteLabel: 'sessions.repertoire.table.delete'|trans({}, 'sessions') } only %}
                                    </div>
                                </td>
                                <td><span class="internal-badge internal-badge--{{ item.active ? 'secondary' : 'primary' }}">{{ (item.active ? 'sessions.catalog.available' : 'sessions.catalog.unavailable')|trans({}, 'sessions') }}</span></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </section>
</div>
