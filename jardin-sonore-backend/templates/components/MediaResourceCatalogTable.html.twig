<div {{ attributes }} class="instrument-catalog">
    {% set items = this.items %}

    <section class="internal-card">
        <div class="instrument-catalog__controls instrument-catalog__controls--inline">
            <div class="internal-search">
                <div class="internal-search__row">
                    <div class="internal-search__field">
                        <label for="media-query">{{ 'sessions.media.index.search'|trans({}, 'sessions') }}</label>
                        <input
                            id="media-query"
                            type="search"
                            value="{{ query }}"
                            data-model="debounce(300)|query"
                            placeholder="{{ 'sessions.media.index.search_placeholder'|trans({}, 'sessions') }}"
                        >
                    </div>

                    <div class="internal-search__field internal-search__field--compact">
                        <label for="media-type">{{ 'sessions.media.index.type'|trans({}, 'sessions') }}</label>
                        <select id="media-type" data-model="on(change)|type">
                            <option value="">{{ 'sessions.media.index.all_types'|trans({}, 'sessions') }}</option>
                            {% for typeOption in this.typeOptions %}
                                <option value="{{ typeOption.value }}" {% if type == typeOption.value %}selected{% endif %}>{{ typeOption.translationKey()|trans({}, 'sessions') }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="internal-search__field internal-search__field--compact">
                        <label for="media-active">{{ 'sessions.catalog.active'|trans({}, 'sessions') }}</label>
                        <select id="media-active" data-model="on(change)|activeFilter">
                            <option value="active">{{ 'sessions.catalog.active_only'|trans({}, 'sessions') }}</option>
                            <option value="inactive">{{ 'sessions.catalog.inactive_only'|trans({}, 'sessions') }}</option>
                            <option value="all">{{ 'sessions.catalog.all'|trans({}, 'sessions') }}</option>
                        </select>
                    </div>
                    <div class="internal-search__field internal-search__field--themes">
                        <span>{{ 'sessions.media.form.themes'|trans({}, 'sessions') }}</span>
                        <div class="instrument-catalog__tags">
                            {% for themeOption in this.themeOptions %}
                                <button type="button" class="internal-badge internal-badge--color instrument-catalog__tag-filter {{ themeOption.uuid in themeUuids ? 'is-selected' : '' }}" style="--badge-color: {{ themeOption.color }}" {{ live_action('toggleTheme', { uuid: themeOption.uuid }) }} aria-pressed="{{ themeOption.uuid in themeUuids ? 'true' : 'false' }}">{{ themeOption.label }}</button>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="instrument-catalog__meta">
            <p>{{ 'sessions.media.index.total'|trans({ count: items|length }, 'sessions') }}</p>

            {% if this.hasActiveFilters %}
                <button
                    type="button"
                    class="internal-button internal-button--secondary internal-button--compact"
                    {{ live_action('resetFilters') }}
                >
                    {{ 'sessions.media.index.reset'|trans({}, 'sessions') }}
                </button>
            {% endif %}
        </div>

        {% if items is empty %}
            <p class="internal-empty-state">{{ 'sessions.media.index.empty'|trans({}, 'sessions') }}</p>
        {% else %}
            <div class="internal-table-wrapper">
                <label class="internal-table__mobile-sort">
                    <span>Trier les ressources</span>
                    <select data-model="on(change)|sortBy">
                        <option value="updatedAt" {% if sortBy == 'updatedAt' %}selected{% endif %}>Dernière mise à jour</option>
                        <option value="title" {% if sortBy == 'title' %}selected{% endif %}>Titre</option>
                        <option value="type" {% if sortBy == 'type' %}selected{% endif %}>Type</option>
                        <option value="source" {% if sortBy == 'source' %}selected{% endif %}>Source</option>
                    </select>
                </label>
                <table class="internal-table internal-table--compact-mobile">
                    <thead>
                        <tr>
                            {% for column, label in {
                                title: 'sessions.media.table.title',
                                type: 'sessions.media.table.type',
                                primaryUrl: 'sessions.media.table.link',
                                source: 'sessions.media.table.source'
                                ,theme: 'sessions.media.table.themes'
                            } %}
                                <th>
                                    <button
                                        type="button"
                                        class="instrument-catalog__sort-button{% if this.isSortedBy(column) %} is-active{% endif %}"
                                        {{ live_action('sort', { column: column }) }}
                                    >
                                        <span>{{ label|trans({}, 'sessions') }}</span>
                                        <span aria-hidden="true">{{ this.sortIconFor(column) }}</span>
                                    </button>
                                </th>
                            {% endfor %}
                            <th>{{ 'sessions.media.table.actions'|trans({}, 'sessions') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in items %}
                            <tr class="internal-table__row--clickable" data-table-availability="{{ item.active ? 'active' : 'inactive' }}" tabindex="0" data-controller="catalog-row" data-catalog-row-url-value="{{ path('media_resource_edit', { uuid: item.uuid.toRfc4122 }) }}" data-action="click->catalog-row#navigate keydown->catalog-row#navigateFromKeyboard">
                                <td data-table-mobile="primary" data-label="{{ 'sessions.media.table.title'|trans({}, 'sessions') }}">
                                    <span class="internal-table__availability-dot{{ item.active ? '' : ' internal-table__availability-dot--inactive' }}"></span><strong>{{ item.title }}</strong>
                                    {% if item.description %}
                                        <span class="internal-table-note">
                                            {{ item.description|length > 120 ? item.description|slice(0, 120) ~ '…' : item.description }}
                                        </span>
                                    {% endif %}
                                </td>
                                <td data-table-mobile="secondary" data-label="{{ 'sessions.media.table.type'|trans({}, 'sessions') }}">{{ item.type.translationKey()|trans({}, 'sessions') }}</td>
                                <td data-table-mobile="secondary" data-label="{{ 'sessions.media.table.link'|trans({}, 'sessions') }}">
                                    <a class="internal-link" href="{{ item.primaryUrl }}" target="_blank" rel="noopener noreferrer">
                                        {{ item.primaryUrl|length > 56 ? item.primaryUrl|slice(0, 56) ~ '…' : item.primaryUrl }}
                                    </a>
                                </td>
                                <td data-table-mobile="secondary" data-label="{{ 'sessions.media.table.source'|trans({}, 'sessions') }}">{{ item.source ?? '—' }}</td>
                                <td data-table-mobile="secondary" data-label="{{ 'sessions.media.table.themes'|trans({}, 'sessions') }}"><div class="instrument-catalog__tags">{% for theme in item.themes %}<span class="internal-badge internal-badge--color" style="--badge-color: {{ theme.color }}">{{ theme.label }}</span>{% endfor %}</div></td>
                                <td data-table-mobile="actions" data-catalog-row-ignore data-label="{{ 'sessions.media.table.actions'|trans({}, 'sessions') }}">
                                    <div class="instrument-catalog__actions">
                                        {% if sessionQuery %}
                                            <a class="internal-button internal-button--secondary internal-button--compact" href="{{ path('session_sequence_new', { uuid: sessionQuery, media: item.uuid.toRfc4122 }) }}">
                                                {{ 'sessions.media.table.insert'|trans({}, 'sessions') }}
                                            </a>
                                        {% endif %}
                                        {% include 'components/_catalog_actions.html.twig' with { editUrl: path('media_resource_edit', { uuid: item.uuid.toRfc4122 }), deleteUrl: path('media_resource_delete', { uuid: item.uuid.toRfc4122 }), itemLabel: item.title, token: csrf_token('media_resource_delete_' ~ item.uuid.toRfc4122), editLabel: 'sessions.media.table.edit'|trans({}, 'sessions'), deleteLabel: 'sessions.media.table.delete'|trans({}, 'sessions') } only %}
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </section>
</div>
