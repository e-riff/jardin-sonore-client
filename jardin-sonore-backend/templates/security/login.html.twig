{% extends 'base.html.twig' %}

{% block title %}{{ 'security.login.title'|trans({}, 'security') }}{% endblock %}

{% block body %}
    <main style="min-height: 100vh; display: grid; place-items: center; background: #f5f2ed; font-family: system-ui, sans-serif;">
        <form method="post" style="width: min(100% - 32px, 380px); display: grid; gap: 16px; padding: 24px; background: #fff; border: 1px solid #ded8ce; border-radius: 8px;">
            <h1 style="margin: 0; font-size: 1.4rem;">{{ 'security.login.heading'|trans({}, 'security') }}</h1>

            {% if error %}
                <p style="margin: 0; color: #9f1239;">{{ error.messageKey|trans(error.messageData, 'security') }}</p>
            {% endif %}

            <label style="display: grid; gap: 6px;">
                <span>{{ 'security.login.email'|trans({}, 'security') }}</span>
                <input type="email" name="_username" value="{{ last_username }}" autocomplete="email" required autofocus style="padding: 10px 12px; border: 1px solid #b8afa2; border-radius: 6px;">
            </label>

            <label style="display: grid; gap: 6px;">
                <span>{{ 'security.login.password'|trans({}, 'security') }}</span>
                <input type="password" name="_password" autocomplete="current-password" required style="padding: 10px 12px; border: 1px solid #b8afa2; border-radius: 6px;">
            </label>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <label style="display: flex; align-items: center; gap: 8px;">
                <input type="checkbox" name="_remember_me" value="1">
                <span>{{ 'security.login.remember_me'|trans({}, 'security') }}</span>
            </label>

            <button type="submit" style="padding: 11px 14px; border: 0; border-radius: 6px; background: #23423d; color: #fff; font-weight: 700;">
                {{ 'security.login.submit'|trans({}, 'security') }}
            </button>
        </form>
    </main>
{% endblock %}
