{% extends 'internal/base.html.twig' %}

{% set title = 'mailing.audience.extend.title'|trans({ campaign: campaign.internalTitle }, 'mailing') %}

{% block internal_body %}
    <section class="internal-page-heading">
        <div>
            <p class="internal-eyebrow">{{ 'mailing.audience.extend.eyebrow'|trans({}, 'mailing') }}</p>
            <h1>{{ campaign.internalTitle }}</h1>
            <p>{{ 'mailing.audience.extend.description'|trans({}, 'mailing') }}</p>
        </div>

        <div class="internal-heading-actions">
            <a class="internal-button internal-button--secondary" href="{{ path('mailing_audience', {
                uuid: campaign.uuid,
                returnTo: returnTo ?: path('mailing_index')
            }) }}">
                {{ 'mailing.audience.extend.back_to_audience'|trans({}, 'mailing') }}
            </a>
            <a class="internal-button internal-button--secondary" href="{{ returnTo ?: path('mailing_index') }}">
                {{ 'mailing.audience.extend.back'|trans({}, 'mailing') }}
            </a>
        </div>
    </section>

    {% if audienceExtensionResult %}
        <section class="internal-card internal-card--compact">
            <div>
                <p class="internal-eyebrow">{{ 'mailing.audience.extend.last_run_eyebrow'|trans({}, 'mailing') }}</p>
                <h2>{{ 'mailing.audience.extend.last_run_title'|trans({}, 'mailing') }}</h2>
            </div>

            <div class="internal-stats-grid">
                <article class="internal-stat-card">
                    <strong>{{ audienceExtensionResult.matchedRecipientCount }}</strong>
                    <span>{{ 'mailing.audience.extend.result.matched'|trans({}, 'mailing') }}</span>
                </article>
                <article class="internal-stat-card">
                    <strong>{{ audienceExtensionResult.alreadyLinkedRecipientCount }}</strong>
                    <span>{{ 'mailing.audience.extend.result.already_linked'|trans({}, 'mailing') }}</span>
                </article>
                <article class="internal-stat-card">
                    <strong>{{ audienceExtensionResult.newRecipientCount }}</strong>
                    <span>{{ 'mailing.audience.extend.result.new'|trans({}, 'mailing') }}</span>
                </article>
            </div>
        </section>
    {% endif %}

    <details class="internal-card mailing-audience__mask-card">
        <summary class="mailing-audience__mask-summary">
            <div>
                <p class="internal-eyebrow">{{ 'mailing.audience.extend.mask.eyebrow'|trans({}, 'mailing') }}</p>
                <h2>{{ 'mailing.audience.extend.mask.title'|trans({}, 'mailing') }}</h2>
            </div>

            <div class="mailing-audience__mask-summary-meta">
                <span class="help-text">
                    {{ 'mailing.audience.mask.count'|trans({ count: audienceMasks|length }, 'mailing') }}
                </span>
            </div>
        </summary>

        <div class="mailing-audience__mask-content">
            <p>{{ 'mailing.audience.extend.mask.description'|trans({}, 'mailing') }}</p>

            {% if selectedAudienceMask %}
                <p class="help-text">{{ 'mailing.audience.extend.mask.current'|trans({ name: selectedAudienceMask.name }, 'mailing') }}</p>
            {% endif %}

            {% if audienceMasks is empty %}
                <p>{{ 'mailing.audience.mask.empty'|trans({}, 'mailing') }}</p>
            {% else %}
                <div class="internal-table-wrapper">
                    <table class="internal-table internal-table--responsive">
                        <thead>
                            <tr>
                                <th>{{ 'mailing.audience.mask.table.name'|trans({}, 'mailing') }}</th>
                                <th>{{ 'mailing.audience.mask.table.municipalities'|trans({}, 'mailing') }}</th>
                                <th>{{ 'mailing.audience.mask.table.actions'|trans({}, 'mailing') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for audienceMask in audienceMasks %}
                                <tr>
                                    <td data-label="{{ 'mailing.audience.mask.table.name'|trans({}, 'mailing') }}">
                                        <strong>{{ audienceMask.name }}</strong>
                                    </td>
                                    <td data-label="{{ 'mailing.audience.mask.table.municipalities'|trans({}, 'mailing') }}">
                                        {{ audienceMask.materializedMunicipalityInseeCodes|length }}
                                    </td>
                                    <td data-label="{{ 'mailing.audience.mask.table.actions'|trans({}, 'mailing') }}">
                                        <a
                                            class="internal-button internal-button--secondary internal-button--compact"
                                            href="{{ path('mailing_audience_extend', {
                                                uuid: campaign.uuid,
                                                mask: audienceMask.uuid.toRfc4122,
                                                returnTo: returnTo ?: path('mailing_index')
                                            }) }}"
                                        >
                                            {{ audienceMask.uuid.toRfc4122 == selectedAudienceMaskUuid ? 'mailing.audience.extend.mask.selected'|trans({}, 'mailing') : 'mailing.audience.extend.mask.use'|trans({}, 'mailing') }}
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </details>

    {{ component('MailingAudience', {
        campaignUuid: campaign.uuid.toRfc4122,
        extensionMode: true,
        initialAudienceMaskUuid: selectedAudienceMaskUuid,
        returnTo: returnTo ?: path('mailing_audience_extend', { uuid: campaign.uuid })
    }) }}
{% endblock %}
