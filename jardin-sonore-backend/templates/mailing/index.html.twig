{% extends 'internal/base.html.twig' %}

{% set title = 'mailing.index.title'|trans({}, 'mailing') %}

{% block internal_body %}
    <section class="internal-page-heading">
        <div>
            <p class="internal-eyebrow">{{ 'mailing.index.eyebrow'|trans({}, 'mailing') }}</p>
            <h1>{{ 'mailing.index.heading'|trans({}, 'mailing') }}</h1>
            <p>{{ 'mailing.index.description'|trans({}, 'mailing') }}</p>
        </div>

        <span class="internal-badge internal-badge--secondary">{{ 'mailing.index.status'|trans({}, 'mailing') }}</span>
    </section>

    <section class="internal-card">
        <h2>{{ 'mailing.index.roadmap.title'|trans({}, 'mailing') }}</h2>
        <p>
            {{ 'mailing.index.roadmap.description'|trans({}, 'mailing') }}
        </p>

        <ul class="internal-checklist">
            <li>{{ 'mailing.index.roadmap.item_model'|trans({}, 'mailing') }}</li>
            <li>{{ 'mailing.index.roadmap.item_targeting'|trans({}, 'mailing') }}</li>
            <li>{{ 'mailing.index.roadmap.item_preview'|trans({}, 'mailing') }}</li>
            <li>{{ 'mailing.index.roadmap.item_test_send'|trans({}, 'mailing') }}</li>
        </ul>
    </section>
{% endblock %}
