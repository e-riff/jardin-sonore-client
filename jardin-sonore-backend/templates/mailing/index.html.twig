{% extends 'internal/base.html.twig' %}

{% set title = 'mailing.index.title'|trans({}, 'mailing') %}

{% block internal_body %}
    <section class="internal-page-heading">
        <div>
            <p class="internal-eyebrow">{{ 'mailing.index.eyebrow'|trans({}, 'mailing') }}</p>
            <h1>{{ 'mailing.index.heading'|trans({}, 'mailing') }}</h1>
            <p>{{ 'mailing.index.description'|trans({}, 'mailing') }}</p>
        </div>

        <a class="internal-button" href="{{ path('mailing_new') }}">{{ 'mailing.index.create'|trans({}, 'mailing') }}</a>
    </section>

    <section class="internal-card">
        <h2>{{ 'mailing.index.list.title'|trans({}, 'mailing') }}</h2>

        {% if campaigns is empty %}
            <div class="internal-empty">
                <p>{{ 'mailing.index.empty'|trans({}, 'mailing') }}</p>
                <a class="internal-button" href="{{ path('mailing_new') }}">{{ 'mailing.index.empty_action'|trans({}, 'mailing') }}</a>
            </div>
        {% else %}
            <div class="internal-table-wrapper">
                <table class="internal-table">
                    <thead>
                    <tr>
                        <th>{{ 'mailing.index.table.internal_title'|trans({}, 'mailing') }}</th>
                        <th>{{ 'mailing.index.table.email_subject'|trans({}, 'mailing') }}</th>
                        <th>{{ 'mailing.index.table.status'|trans({}, 'mailing') }}</th>
                        <th>{{ 'mailing.index.table.audience'|trans({}, 'mailing') }}</th>
                        <th>{{ 'mailing.index.table.updated_at'|trans({}, 'mailing') }}</th>
                        <th>{{ 'mailing.index.table.actions'|trans({}, 'mailing') }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for campaign in campaigns %}
                        <tr>
                            <td>{{ campaign.internalTitle }}</td>
                            <td>{{ campaign.emailSubject }}</td>
                            <td>
                                <span class="internal-badge internal-badge--secondary">
                                    {{ ('mailing.status.' ~ campaign.status.value)|trans({}, 'mailing') }}
                                </span>
                            </td>
                            <td>
                                {% if campaign.hasAudienceCriteria %}
                                    <span class="internal-badge internal-badge--primary">
                                        {{ 'mailing.index.audience.configured'|trans({}, 'mailing') }}
                                    </span>
                                    <span class="internal-table-note">
                                        {% if campaign.audienceRecipientCount is not null %}
                                            {{ 'mailing.index.audience.recipients'|trans({ count: campaign.audienceRecipientCount }, 'mailing') }}
                                        {% else %}
                                            {{ 'mailing.index.audience.count_unavailable'|trans({}, 'mailing') }}
                                        {% endif %}
                                    </span>
                                {% else %}
                                    <span class="internal-badge internal-badge--muted">
                                        {{ 'mailing.index.audience.empty'|trans({}, 'mailing') }}
                                    </span>
                                    <span class="internal-table-note">
                                        {{ 'mailing.index.audience.empty_help'|trans({}, 'mailing') }}
                                    </span>
                                {% endif %}
                            </td>
                            <td>{{ campaign.updatedAt|date('d/m/Y H:i') }}</td>
                            <td>
                                <div class="mailing-index__actions">
                                    <a class="internal-button internal-button--secondary internal-button--compact" href="{{ path('mailing_content', { uuid: campaign.uuid }) }}">
                                        {{ 'mailing.index.edit'|trans({}, 'mailing') }}
                                    </a>
                                    {% if campaign.isEditable %}
                                        <a class="internal-button internal-button--secondary internal-button--compact" href="{{ path('mailing_audience', {
                                            uuid: campaign.uuid,
                                            returnTo: path('mailing_index')
                                        }) }}">
                                            {{ 'mailing.index.audience.edit'|trans({}, 'mailing') }}
                                        </a>
                                    {% endif %}
                                    <a class="internal-button internal-button--secondary internal-button--compact" href="{{ path('mailing_preview', { uuid: campaign.uuid }) }}">
                                        {{ 'mailing.index.preview'|trans({}, 'mailing') }}
                                    </a>
                                    <a class="internal-button internal-button--secondary internal-button--compact" href="{{ path('mailing_test', { uuid: campaign.uuid }) }}">
                                        {{ 'mailing.index.test'|trans({}, 'mailing') }}
                                    </a>
                                    {% if campaign.isEditable %}
                                        <a class="internal-button internal-button--secondary internal-button--compact" href="{{ path('mailing_send', { uuid: campaign.uuid }) }}">
                                            {{ 'mailing.index.send'|trans({}, 'mailing') }}
                                        </a>
                                    {% endif %}
                                    {% if campaign.canStopDelivery %}
                                        <form method="post" action="{{ path('mailing_stop', { uuid: campaign.uuid }) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('mailing_stop_' ~ campaign.uuid) }}">
                                            <button class="internal-button internal-button--danger internal-button--compact" type="submit">
                                                {{ 'mailing.index.stop'|trans({}, 'mailing') }}
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </section>
{% endblock %}
