{% extends 'internal/base.html.twig' %}

{% set title = 'mailing.audience.mask.catalog_title'|trans({}, 'mailing') %}

{% block internal_body %}
    <section class="internal-page-heading">
        <div>
            <p class="internal-eyebrow">{{ 'mailing.audience.mask.catalog_eyebrow'|trans({}, 'mailing') }}</p>
            <h1>{{ 'mailing.audience.mask.catalog_heading'|trans({}, 'mailing') }}</h1>
            <p>{{ 'mailing.audience.mask.catalog_description'|trans({}, 'mailing') }}</p>
        </div>

        <div class="internal-heading-actions">
            {% if campaign %}
                <a class="internal-button" href="{{ path('mailing_audience', { uuid: campaign.uuid }) }}">
                    {{ 'mailing.audience.mask.back_to_campaign'|trans({}, 'mailing') }}
                </a>
            {% else %}
                <a class="internal-button internal-button--secondary" href="{{ path('mailing_index') }}">
                    {{ 'mailing.audience.mask.back_to_mailing'|trans({}, 'mailing') }}
                </a>
            {% endif %}
        </div>
    </section>

    <section class="internal-card">
        {% if audienceMasks is empty %}
            <p>{{ 'mailing.audience.mask.empty'|trans({}, 'mailing') }}</p>
        {% else %}
            <div class="internal-table-wrapper">
                <twig:TableMobileSort label="Trier les masques" :selected="tableSort.column" :options="[
                    { value: 'name', label: 'Nom', href: path('mailing_audience_mask_index', { campaign: campaign ? campaign.uuid : null, sort: 'name', direction: tableSort.nextDirectionFor('name') }) },
                    { value: 'municipalityCount', label: 'Communes', href: path('mailing_audience_mask_index', { campaign: campaign ? campaign.uuid : null, sort: 'municipalityCount', direction: tableSort.nextDirectionFor('municipalityCount') }) }
                ]" />
                <table class="internal-table internal-table--compact-mobile">
                    <thead>
                        <tr>
                            <th><twig:TableSortHeader label="{{ 'mailing.audience.mask.table.name'|trans({}, 'mailing') }}" :href="path('mailing_audience_mask_index', { campaign: campaign ? campaign.uuid : null, sort: 'name', direction: tableSort.nextDirectionFor('name') })" :active="tableSort.column == 'name'" :direction="tableSort.direction" /></th>
                            <th data-table-mobile="secondary"><twig:TableSortHeader label="{{ 'mailing.audience.mask.table.municipalities'|trans({}, 'mailing') }}" :href="path('mailing_audience_mask_index', { campaign: campaign ? campaign.uuid : null, sort: 'municipalityCount', direction: tableSort.nextDirectionFor('municipalityCount') })" :active="tableSort.column == 'municipalityCount'" :direction="tableSort.direction" /></th>
                            <th>{{ 'mailing.audience.mask.table.actions'|trans({}, 'mailing') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for audienceMask in audienceMasks %}
                            <tr>
                                <td data-table-mobile="primary" data-label="{{ 'mailing.audience.mask.table.name'|trans({}, 'mailing') }}"><strong>{{ audienceMask.name }}</strong></td>
                                <td data-table-mobile="secondary" data-label="{{ 'mailing.audience.mask.table.municipalities'|trans({}, 'mailing') }}">{{ audienceMask.materializedMunicipalityInseeCodes|length }}</td>
                                <td data-table-mobile="actions" data-label="{{ 'mailing.audience.mask.table.actions'|trans({}, 'mailing') }}">
                                    {% if campaign %}
                                        <form method="post" action="{{ path('mailing_audience_mask_apply_to_campaign', {
                                            maskUuid: audienceMask.uuid,
                                            campaignUuid: campaign.uuid
                                        }) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('mailing_apply_audience_mask_' ~ audienceMask.uuid.toRfc4122 ~ '_' ~ campaign.uuid.toRfc4122) }}">
                                            <button class="internal-button internal-button--secondary internal-button--compact" type="submit" {% if not campaign.editable %}disabled{% endif %}>
                                                {{ 'mailing.audience.mask.apply'|trans({}, 'mailing') }}
                                            </button>
                                        </form>
                                    {% else %}
                                        <span class="help-text">{{ 'mailing.audience.mask.apply_help'|trans({}, 'mailing') }}</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </section>
{% endblock %}
