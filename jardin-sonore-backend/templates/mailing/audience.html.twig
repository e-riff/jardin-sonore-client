{% extends 'internal/base.html.twig' %}

{% set title = 'mailing.audience.title'|trans({ campaign: campaign.internalTitle }, 'mailing') %}

{% block internal_body %}
    <section class="internal-page-heading">
        <div>
            <p class="internal-eyebrow">{{ 'mailing.audience.eyebrow'|trans({}, 'mailing') }}</p>
            <h1>{{ campaign.internalTitle }}</h1>
            <p>{{ 'mailing.audience.description'|trans({}, 'mailing') }}</p>
        </div>

        <div class="internal-heading-actions">
            {% if campaign.canExtendAudience %}
                <a class="internal-button" href="{{ path('mailing_audience_extend', {
                    uuid: campaign.uuid,
                    returnTo: returnTo ?: path('mailing_content', { uuid: campaign.uuid })
                }) }}">
                    {{ 'mailing.audience.extend.open'|trans({}, 'mailing') }}
                </a>
            {% endif %}
            <a class="internal-button" href="{{ path('mailing_audience_mask_index', { campaign: campaign.uuid }) }}">
                {{ 'mailing.audience.mask.open_catalog'|trans({}, 'mailing') }}
            </a>
            <a class="internal-button internal-button--secondary" href="{{ returnTo ?: path('mailing_content', { uuid: campaign.uuid }) }}">
                {{ 'mailing.audience.back'|trans({}, 'mailing') }}
            </a>
        </div>
    </section>

    <details class="internal-card mailing-audience__mask-card">
        <summary class="mailing-audience__mask-summary">
            <div>
                <p class="internal-eyebrow">{{ 'mailing.audience.mask.eyebrow'|trans({}, 'mailing') }}</p>
                <h2>{{ 'mailing.audience.mask.title'|trans({}, 'mailing') }}</h2>
            </div>

            <div class="mailing-audience__mask-summary-meta">
                <span class="help-text">
                    {{ 'mailing.audience.mask.count'|trans({ count: audienceMasks|length }, 'mailing') }}
                </span>
            </div>
        </summary>

        <div class="mailing-audience__mask-content">
            <p>{{ 'mailing.audience.mask.description'|trans({}, 'mailing') }}</p>

            {{ form_start(audienceMaskForm, { attr: { class: 'internal-form', 'data-mailing-audience-mask-form': 'true' } }) }}
                <div class="mailing-audience__mask-form-row">
                    <div class="mailing-audience__mask-form-field">
                        {{ form_row(audienceMaskForm.name) }}
                    </div>
                    <div class="mailing-audience__mask-form-submit">
                        {{ form_widget(audienceMaskForm.submit) }}
                    </div>
                </div>
                {{ form_widget(audienceMaskForm.currentAudienceSnapshot) }}
            {{ form_end(audienceMaskForm) }}

            <div class="mailing-audience__mask-table-header">
                <h3>{{ 'mailing.audience.mask.available_title'|trans({}, 'mailing') }}</h3>
            </div>

            {% if audienceMasks is empty %}
                <p>{{ 'mailing.audience.mask.empty'|trans({}, 'mailing') }}</p>
            {% else %}
                <div class="internal-table-wrapper">
                    <table class="internal-table internal-table--responsive">
                        <thead>
                            <tr>
                                <th>{{ 'mailing.audience.mask.table.name'|trans({}, 'mailing') }}</th>
                                <th>{{ 'mailing.audience.mask.table.municipalities'|trans({}, 'mailing') }}</th>
                                <th>{{ 'mailing.audience.mask.table.actions'|trans({}, 'mailing') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for audienceMask in audienceMasks %}
                                <tr>
                                    <td data-label="{{ 'mailing.audience.mask.table.name'|trans({}, 'mailing') }}"><strong>{{ audienceMask.name }}</strong></td>
                                    <td data-label="{{ 'mailing.audience.mask.table.municipalities'|trans({}, 'mailing') }}">{{ audienceMask.materializedMunicipalityInseeCodes|length }}</td>
                                    <td data-label="{{ 'mailing.audience.mask.table.actions'|trans({}, 'mailing') }}">
                                        <form method="post" action="{{ path('mailing_audience_mask_apply_to_campaign', {
                                            maskUuid: audienceMask.uuid,
                                            campaignUuid: campaign.uuid
                                        }) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('mailing_apply_audience_mask_' ~ audienceMask.uuid.toRfc4122 ~ '_' ~ campaign.uuid.toRfc4122) }}">
                                            <button class="internal-button internal-button--secondary internal-button--compact" type="submit" {% if campaignLocked %}disabled{% endif %}>
                                                {{ 'mailing.audience.mask.apply'|trans({}, 'mailing') }}
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </details>

    {{ component('MailingAudience', {
        campaignUuid: campaign.uuid.toRfc4122,
        locked: campaignLocked,
        returnTo: returnTo ?: path('mailing_content', { uuid: campaign.uuid })
    }) }}
{% endblock %}
