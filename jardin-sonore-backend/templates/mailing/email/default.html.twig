<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{{ campaign.emailSubject }}</title>
    </head>
    <body bgcolor="#f3ede9" style="margin:0; padding:0; background-color:#f3ede9; color:#1c1b1a; font-family:Georgia, serif;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
            <tr>
                <td style="font-size:1px; line-height:1px; color:#f3ede9; display:none;">
                    {{ preheader }}
                </td>
            </tr>
        </table>

        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" bgcolor="#f3ede9">
            <tr>
                <td align="center" style="padding:24px 12px;">
                    <table role="presentation" width="600" cellspacing="0" cellpadding="0" border="0" bgcolor="#fffdfa" style="width:600px; max-width:600px; background-color:#fffdfa;">
                        <tr>
                            <td align="center" style="padding:32px 24px 18px 24px;">
                                <h1 style="margin:0; color:#692019; font-size:24px; line-height:30px; font-weight:bold;">
                                    Jardin <span style="color:#47664b;">Sonore</span>
                                </h1>
                                <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin-top:12px;">
                                    <tr>
                                        <td width="42" height="4" bgcolor="#A64D43" style="font-size:0; line-height:0;">&nbsp;</td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding:0;">
                                <img
                                    src="{{ absolute_url(asset(heroImagePath)) }}"
                                    alt=""
                                    width="600"
                                    style="display:block; width:100%; height:auto; border:0; outline:none; text-decoration:none;"
                                >
                            </td>
                        </tr>
                        <tr>
                            <td align="center" bgcolor="#f8f3f0" style="padding:28px 24px 24px 24px; background-color:#f8f3f0;">
                                <h2 style="margin:0; color:#692019; font-size:30px; line-height:36px; font-weight:bold;">{{ campaign.publicTitle }}</h2>
                                {% if campaign.subtitle %}
                                    <p style="margin:12px 0 0 0; color:#554240; font-family:Arial, sans-serif; font-size:13px; line-height:18px; font-weight:bold; text-transform:uppercase;">{{ campaign.subtitle }}</p>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td style="padding:32px 28px 20px 28px;">
                                <div style="color:#554240; font-size:16px; line-height:28px;">{{ mainTextHtml|raw }}</div>
                                {% if campaign.callToActionLabel and campaign.callToActionUrl %}
                                    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-top:24px;">
                                        <tr>
                                            <td align="center">
                                                <table role="presentation" cellspacing="0" cellpadding="0" border="0">
                                                    <tr>
                                                        <td align="center" bgcolor="#A64D43" style="padding:14px 28px; background-color:#A64D43;">
                                                            <a
                                                                href="{{ campaign.callToActionUrl }}"
                                                                style="color:#ffffff; font-family:Arial, sans-serif; font-size:14px; line-height:18px; font-weight:bold; text-decoration:none;"
                                                            >{{ campaign.callToActionLabel }}</a>
                                                        </td>
                                                    </tr>
                                                </table>
                                            </td>
                                        </tr>
                                    </table>
                                {% endif %}
                            </td>
                        </tr>

                        {% if activeRecommendations is not empty %}
                            <tr>
                                <td align="center" bgcolor="#f8f3f0" style="padding:28px 28px 12px 28px; background-color:#f8f3f0;">
                                    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                                        <tr>
                                            <td align="center">
                                                <h3 style="margin:0; color:#53320b; font-size:24px; line-height:32px; font-weight:bold;">
                                                    {{ 'mailing.preview.email.recommendations_title'|trans({}, 'mailing') }}
                                                </h3>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>

                            {% for recommendation in activeRecommendations %}
                                <tr>
                                    <td bgcolor="#f8f3f0" style="padding:0 28px 20px 28px; background-color:#f8f3f0;">
                                        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" bgcolor="#fffdfa" style="background-color:#fffdfa; border:1px solid #eadfd7;">
                                            <tr>
                                                <td width="152" valign="middle" align="center" style="padding:16px 8px 16px 16px;">
                                                    {% if recommendation.imagePath %}
                                                        {% if recommendation.url %}
                                                            <a href="{{ recommendation.url }}" target="_blank" style="display:block; text-decoration:none;">
                                                                <img
                                                                    src="{{ absolute_url(asset(recommendation.imagePath)) }}"
                                                                    alt=""
                                                                    width="128"
                                                                    height="128"
                                                                    style="display:block; width:128px; height:128px; margin:0 auto; border:0; outline:none; text-decoration:none; object-fit:cover;"
                                                                >
                                                            </a>
                                                        {% else %}
                                                            <img
                                                                src="{{ absolute_url(asset(recommendation.imagePath)) }}"
                                                                alt=""
                                                                width="128"
                                                                height="128"
                                                                style="display:block; width:128px; height:128px; margin:0 auto; border:0; outline:none; text-decoration:none; object-fit:cover;"
                                                            >
                                                        {% endif %}
                                                    {% else %}
                                                        <table role="presentation" cellspacing="0" cellpadding="0" border="0" align="center">
                                                            <tr>
                                                                <td width="128" height="128" bgcolor="#eadfd7" style="font-size:0; line-height:0;">&nbsp;</td>
                                                            </tr>
                                                        </table>
                                                    {% endif %}
                                                </td>
                                                <td valign="top" style="padding:16px 16px 16px 12px;">
                                                    <h4 style="margin:0 0 10px 0; color:#1c1b1a; font-size:18px; line-height:26px; font-weight:bold;">{{ recommendation.title }}</h4>
                                                    <div style="color:#554240; font-size:14px; line-height:1.7; white-space:pre-line;">{% if recommendation.tag %}<span style="color:{{ loop.index is odd ? '#692019' : '#47664b' }}; font-family:Arial, sans-serif; font-weight:bold;">{{ recommendation.tag }}</span> - {% endif %}{{ recommendation.text }}</div>
                                                    {% if recommendation.url %}
                                                        <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin-top:12px;">
                                                            <tr>
                                                                <td>
                                                                    <a
                                                                        href="{{ recommendation.url }}"
                                                                        style="color:#692019; font-family:Arial, sans-serif; font-size:14px; line-height:18px; font-weight:bold; text-decoration:underline;"
                                                                    >{{ recommendation.linkLabel ?: ('mailing.preview.email.recommendation_default_link_label'|trans({}, 'mailing')) }}</a>
                                                                </td>
                                                            </tr>
                                                        </table>
                                                    {% endif %}
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endif %}

                        <tr>
                            <td align="center" bgcolor="#ece7e4" style="padding:32px 24px 36px 24px; background-color:#ece7e4;">
                                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                                    <tr>
                                        <td align="center">
                                            <p style="margin:0; color:#7a6461; font-family:Arial, sans-serif; font-size:12px; line-height:18px;">
                                                {{ 'mailing.preview.email.footer_notice'|trans({'year': "now"|date('Y')}, 'mailing')|nl2br }}
                                            </p>
                                            <p style="margin:12px 0 0 0; color:#7a6461; font-family:Arial, sans-serif; font-size:12px; line-height:18px;">
                                                <a href="{{ unsubscribeUrl }}" style="color:#7a6461; text-decoration:underline;">{{ 'mailing.preview.email.unsubscribe'|trans({}, 'mailing') }}</a>
                                            </p>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </body>
</html>
