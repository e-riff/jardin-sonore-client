{% extends 'internal/base.html.twig' %}

{% set title = 'mailing.content.title'|trans({ campaign: campaign.internalTitle }, 'mailing') %}

{% block internal_body %}
    <section class="internal-page-heading">
        <div>
            <p class="internal-eyebrow">{{ 'mailing.content.eyebrow'|trans({}, 'mailing') }}</p>
            <h1>{{ campaign.internalTitle }}</h1>
            <p>{{ 'mailing.content.description'|trans({}, 'mailing') }}</p>
        </div>

        <div class="internal-heading-actions">
            <a class="internal-button" href="{{ path('mailing_audience', {
                uuid: campaign.uuid,
                returnTo: path('mailing_content', { uuid: campaign.uuid })
            }) }}">
                {{ 'mailing.content.configure_audience'|trans({}, 'mailing') }}
            </a>
            <a class="internal-button internal-button--secondary" href="{{ path('mailing_preview', { uuid: campaign.uuid }) }}">
                {{ 'mailing.content.preview'|trans({}, 'mailing') }}
            </a>
            <a class="internal-button internal-button--secondary" href="{{ path('mailing_test', { uuid: campaign.uuid }) }}">
                {{ 'mailing.content.send_test'|trans({}, 'mailing') }}
            </a>
            <a class="internal-button internal-button--secondary" href="{{ path('mailing_index') }}">
                {{ 'mailing.content.back'|trans({}, 'mailing') }}
            </a>
        </div>
    </section>

    <section class="internal-card mailing-content-audience">
        <div>
            <p class="internal-eyebrow">{{ 'mailing.content.audience.eyebrow'|trans({}, 'mailing') }}</p>
            <h2>{{ 'mailing.content.audience.title'|trans({}, 'mailing') }}</h2>
        </div>

        <div class="mailing-content-audience__status">
            {% if hasAudienceCriteria %}
                <span class="internal-badge internal-badge--{{ audienceRecipientCount is not null ? 'success' : 'warning' }}">
                    {% if audienceRecipientCount is not null %}
                        {{ 'mailing.index.audience.recipients'|trans({ count: audienceRecipientCount }, 'mailing') }}
                    {% else %}
                        {{ 'mailing.index.audience.count_unavailable'|trans({}, 'mailing') }}
                    {% endif %}
                </span>
            {% else %}
                <span class="internal-badge internal-badge--muted">
                    {{ 'mailing.index.audience.empty'|trans({}, 'mailing') }}
                </span>
                <span class="internal-table-note">
                    {{ 'mailing.index.audience.empty_help'|trans({}, 'mailing') }}
                </span>
            {% endif %}
        </div>
    </section>

    {% if campaignLocked %}
        <section class="internal-card">
            <div class="internal-alert">
                {{ 'mailing.content.locked_notice'|trans({}, 'mailing') }}
            </div>
        </section>
    {% endif %}

    {{ form_start(form, {
        attr: {
            class: 'internal-form internal-form--wide',
            'data-controller': campaignLocked ? '' : 'unsaved-changes',
            'data-unsaved-changes-dirty-value': campaignLocked ? 'false' : (formSubmitted ? 'true' : 'false'),
            'data-unsaved-changes-message-value': 'mailing.content.unsaved_changes_warning'|trans({}, 'mailing')
        }
    }) }}
        <section class="internal-card">
            <div>
                <p class="internal-eyebrow">{{ 'mailing.content.details.eyebrow'|trans({}, 'mailing') }}</p>
                <h2>{{ 'mailing.content.details.title'|trans({}, 'mailing') }}</h2>
            </div>

            <div class="mailing-current-image">
                <img src="{{ asset(form.vars.data.bannerImagePath ?: 'images/mailing/default-banner.webp') }}" alt="">
                <p>
                    {{ (form.vars.data.bannerImagePath ? 'mailing.form.banner_image_current' : 'mailing.form.banner_image_default')|trans({}, 'mailing') }}
                </p>
            </div>

            {{ form_row(form.internalTitle) }}
            {{ form_row(form.emailSubject) }}
            {{ form_row(form.publicTitle) }}
            {{ form_row(form.subtitle) }}
            {{ form_row(form.mainText) }}
            <div class="internal-form__grid">
                {{ form_row(form.callToActionLabel) }}
                {{ form_row(form.callToActionUrl) }}
            </div>
            <div class="mailing-banner-upload">
                {{ form_row(form.bannerImageFile) }}
                {% if form.removeBannerImage is defined and form.vars.data.bannerImagePath %}
                    <div class="mailing-banner-upload__reset">
                        {{ form_widget(form.removeBannerImage) }}
                        {{ form_label(form.removeBannerImage) }}
                    </div>
                    {{ form_help(form.removeBannerImage) }}
                    {{ form_errors(form.removeBannerImage) }}
                {% endif %}
            </div>
            {{ form_row(form.templateKey) }}
        </section>

        {% if not campaignLocked %}
            <div class="internal-form__actions">
                {{ form_widget(form.submit) }}
            </div>
        {% endif %}
    {{ form_end(form) }}

    <turbo-frame
        id="campaign-recommendations"
        src="{{ path('mailing_campaign_recommendation_index', { campaignUuid: campaign.uuid }) }}"
        loading="lazy"
    >
        <section class="internal-card">
            <p>{{ 'mailing.content.recommendations.loading'|trans({}, 'mailing') }}</p>
        </section>
    </turbo-frame>
{% endblock %}
