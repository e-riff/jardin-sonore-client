{% extends 'internal/base.html.twig' %}

{% set title = 'mailing.catalog.index.title'|trans({}, 'mailing') %}

{% block internal_body %}
    <section class="internal-page-heading">
        <div>
            <p class="internal-eyebrow">{{ 'mailing.catalog.index.eyebrow'|trans({}, 'mailing') }}</p>
            <h1>{{ 'mailing.catalog.index.heading'|trans({}, 'mailing') }}</h1>
            <p>{{ 'mailing.catalog.index.description'|trans({}, 'mailing') }}</p>
        </div>

        <a class="internal-button" href="{{ path('mailing_recommendation_catalog_new') }}">
            {{ 'mailing.catalog.index.create'|trans({}, 'mailing') }}
        </a>
    </section>

    <section class="internal-card">
        <form class="internal-search" method="get">
            <label for="catalog-query">{{ 'mailing.catalog.index.search'|trans({}, 'mailing') }}</label>
            <div>
                <input id="catalog-query" name="query" value="{{ query }}">
                <button class="internal-button internal-button--secondary" type="submit">
                    {{ 'mailing.catalog.index.search_submit'|trans({}, 'mailing') }}
                </button>
            </div>
        </form>

        {% if recommendations is empty %}
            <p class="internal-empty-state">{{ 'mailing.catalog.index.empty'|trans({}, 'mailing') }}</p>
        {% else %}
            <div class="internal-table-wrapper">
                <table class="internal-table internal-table--responsive">
                    <thead>
                    <tr>
                        <th>{{ 'mailing.catalog.index.table.visual'|trans({}, 'mailing') }}</th>
                        <th>{{ 'mailing.catalog.index.table.title'|trans({}, 'mailing') }}</th>
                        <th>{{ 'mailing.catalog.index.table.status'|trans({}, 'mailing') }}</th>
                        <th>{{ 'mailing.catalog.index.table.updated_at'|trans({}, 'mailing') }}</th>
                        <th>{{ 'mailing.catalog.index.table.actions'|trans({}, 'mailing') }}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for recommendation in recommendations %}
                        <tr>
                            <td data-label="{{ 'mailing.catalog.index.table.visual'|trans({}, 'mailing') }}">
                                {% if recommendation.imagePath %}
                                    {% if recommendation.url %}
                                        <a class="mailing-catalog-table__media" href="{{ recommendation.url }}" target="_blank" rel="noopener noreferrer">
                                            <img src="{{ asset(recommendation.imagePath) }}" alt="">
                                        </a>
                                    {% else %}
                                        <div class="mailing-catalog-table__media">
                                            <img src="{{ asset(recommendation.imagePath) }}" alt="">
                                        </div>
                                    {% endif %}
                                {% else %}
                                    <span class="internal-table-note">—</span>
                                {% endif %}
                            </td>
                            <td data-label="{{ 'mailing.catalog.index.table.title'|trans({}, 'mailing') }}">
                                {% if recommendation.tag %}
                                    <p class="mailing-catalog-card__tag">{{ recommendation.tag }}</p>
                                {% endif %}
                                <strong>{{ recommendation.title }}</strong>
                                <span class="internal-table-note">{{ recommendation.text }}</span>
                            </td>
                            <td data-label="{{ 'mailing.catalog.index.table.status'|trans({}, 'mailing') }}">
                                <span class="internal-badge internal-badge--{{ recommendation.active ? 'secondary' : 'primary' }}">
                                    {{ (recommendation.active ? 'mailing.catalog.status.active' : 'mailing.catalog.status.inactive')|trans({}, 'mailing') }}
                                </span>
                            </td>
                            <td data-label="{{ 'mailing.catalog.index.table.updated_at'|trans({}, 'mailing') }}">
                                {{ recommendation.updatedAt|date('d/m/Y H:i') }}
                            </td>
                            <td data-label="{{ 'mailing.catalog.index.table.actions'|trans({}, 'mailing') }}">
                                <a class="internal-button internal-button--secondary internal-button--compact" href="{{ path('mailing_recommendation_catalog_edit', {
                                    uuid: recommendation.uuid
                                }) }}">
                                    {{ 'mailing.catalog.index.edit'|trans({}, 'mailing') }}
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </section>
{% endblock %}
