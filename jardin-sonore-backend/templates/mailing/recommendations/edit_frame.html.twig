{% extends '@Turbo/layouts/frame.html.twig' %}

{% block body %}
    <turbo-frame id="campaign-recommendations">
        <section class="internal-card">
            <div>
                <p class="internal-eyebrow">{{ 'mailing.content.recommendations.edit_eyebrow'|trans({}, 'mailing') }}</p>
                <h2>{{ recommendation.title }}</h2>
                <p>{{ 'mailing.content.recommendations.edit_description'|trans({}, 'mailing') }}</p>
            </div>

            {{ form_start(form, {
                action: path('mailing_campaign_recommendation_edit', {
                    campaignUuid: campaign.uuid,
                    recommendationUuid: recommendation.uuid
                }),
                attr: { class: 'internal-form' }
            }) }}
                {{ form_row(form.title) }}
                {{ form_row(form.text) }}
                {{ form_row(form.url) }}
                {{ form_row(form.linkLabel) }}
                {{ form_row(form.active) }}
                <div class="internal-form__actions">
                    {{ form_widget(form.submit) }}
                    <a class="internal-button internal-button--secondary" href="{{ path('mailing_campaign_recommendation_index', {
                        campaignUuid: campaign.uuid
                    }) }}">
                        {{ 'mailing.content.recommendations.cancel'|trans({}, 'mailing') }}
                    </a>
                </div>
            {{ form_end(form) }}
        </section>
    </turbo-frame>
{% endblock %}
